        hbox = {
            layoutpolicy_horizontal = expanding

            widget = {
                layoutpolicy_horizontal = expanding
                size = { 0 26 }

                background = {
                    using = Background_Area_Dark

                    modify_texture = {
                        texture = "gfx/interface/component_masks/mask_fade_horizontal_right.dds"
                        blend_mode = alphamultiply
                    }
                }

                text_label_left = {
                    layoutpolicy_horizontal = expanding
                    align = left
                    margin = { 0 3 }
                    text = "DI_ek_special_buildings_cyrodiil"
                }

                button_standard = {
                    parentanchor = left|vcenter
                    size = { 100% 100% }
                    alpha = 0
                    text = ""
                    onclick = "[GetVariableSystem.Toggle('DI_TM_ek_special_buildings_cyrodiil_open')]"
                }
            }

            button_list_expand = {
                checked = "[GetVariableSystem.Exists('DI_TM_ek_special_buildings_cyrodiil_open')]"
                onclick = "[GetVariableSystem.Toggle('DI_TM_ek_special_buildings_cyrodiil_open')]"
            }
        }

