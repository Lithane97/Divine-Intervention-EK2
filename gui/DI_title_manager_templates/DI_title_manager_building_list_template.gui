                    parentanchor = left|vcenter
                    margin_left = 8
                    text = "building_type_the_great_wall_shanhai_pass"
                    default_format = "#low"
                    }
            }

            button_standard_clean = {
                layoutpolicy_horizontal = expanding
                size = { 0 44 }
                enabled = "[GetScriptedGui('DI_tm_building_the_great_wall_liaodong_sgui').IsValid(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
                onclick = "[GetScriptedGui('DI_tm_building_the_great_wall_liaodong_sgui').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
                onrightclick = "[GetScriptedGui('DI_tm_destroy_building_the_great_wall_liaodong_sgui').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
                button_ignore = none
                tooltip = "DI_tm_building_button_tt"
                using = tooltip_w

                background = { using = Background_Area_Dark }

                text_single = {
                    parentanchor = left|vcenter
                    margin_left = 8
                    text = "building_type_the_great_wall_liaodong"
                    default_format = "#low"
                    }
            }
        }
    }
}
